# -----------------------------------------------------------------------------
# CoPaw / Mazepaw — 环境变量示例（复制为 .env 并按需填写）
# 进程环境优先；`copaw app` 启动时会依次尝试加载当前目录与 COPAW_WORKING_DIR 下的 `.env`
#（已有 export 的变量不会被覆盖）。Docker 仍可用 env_file 注入。
#
# Python 依赖推荐用 uv：仓库根目录执行 `uv sync`（见 README「从源码安装」），再 `uv run copaw app`。
# -----------------------------------------------------------------------------

# --- Web 控制台总开关（必选：要保护外网控制台时请开启）---
# true / 1 / yes
COPAW_AUTH_ENABLED=true

# =============================================================================
# 飞书登录（可选；与上方同时启用时，控制台可出现「飞书登录」并校验企业租户）
# =============================================================================
#
# 为什么只有 FEISHU_APP_ID / FEISHU_APP_SECRET 不够？
# - 二者只标识你的「应用」，不能自动判断「是不是你们公司的人」。
# - OAuth 还必须：在飞书里登记 redirect URI、用 code 换 user_access_token，
#   再从返回里取 tenant_key，与你们允许的租户比对（见 FEISHU_ALLOWED_TENANT_KEYS）。
#
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx
# 必须与飞书开放平台「安全设置 → 重定向 URL」里配置的地址完全一致，例如：
FEISHU_REDIRECT_URI=https://你的域名/api/auth/callback/feishu
# 允许的飞书 tenant_key（企业租户唯一标识），逗号分隔，不是应用在授权 URL 里的参数。
# 它出现在：用 code 换 token 的接口返回 JSON 的 data.tenant_key，以及 user_info 的 data.tenant_key；
# 授权页链上的 client_id/scope/state 等都不是 tenant_key。
# 首次可填占位；用本企账号完成授权后若登录页提示「仅允许本企业」，此时看运行 copaw 的终端日志里
# 「received tenant_key='…'」一行，把该字符串写入本变量后重启再登录。
FEISHU_ALLOWED_TENANT_KEYS=your_tenant_key

# --- 飞书 OAuth 授权范围（scope）---
# 不需要配置。控制台登录在代码里固定使用最小 scope（仅通讯录只读基础信息 + 邮箱），
# 避免再增加环境变量；若飞书侧未开通对应权限，请到开放平台为应用勾选对应权限。

# --- 反代 / 路径（多数部署可省略）---
# HTTPS 终止在反向代理时，可设为对外的 https://域名，用于 OAuth 回调后跳回登录页
# COPAW_PUBLIC_ORIGIN=https://你的域名
# 若用户只通过 /console/ 访问 SPA，可设 /console（否则可从首次跳转路径自动推断）
# COPAW_CONSOLE_BASE_PATH=

# =============================================================================
# 其他 CoPaw 变量（节选，完整见文档与 Dockerfile）
# =============================================================================
# COPAW_WORKING_DIR=
# COPAW_SECRET_DIR=
# CORS_ORIGINS=
